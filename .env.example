# ═══════════════════════════════════════════════════════════════
# AI-Stack Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!
# ═══════════════════════════════════════════════════════════════

# ── OpenRouter API ───────────────────────────────────────────
# Required for cloud models (Claude, GPT-4, Gemini, etc.)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# ── Authentication ────────────────────────────────────────────
# Set to true to enable authentication
WEBUI_AUTH=true

# Admin credentials
# IMPORTANT: Change these to strong, unique values!
# Run: openssl rand -base64 24  (to generate secure passwords)
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme123

# ── Ollama Configuration ───────────────────────────────────────
# URL for local Ollama instance (default: host machine)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default model to use when starting
DEFAULT_MODEL=llama3.2

# ── WebUI Configuration ───────────────────────────────────────
# Name displayed in the web interface
WEBUI_NAME=AI-Stack

# Public URL for the WebUI (change for production)
WEBUI_URL=http://localhost:3000

# ── ChromaDB (Vector Database) ────────────────────────────────
# Disable telemetry for privacy
CHROMA_TELEMETRY=false

# Allowed origins (comma-separated)
CHROMA_ORIGINS=http://localhost:3000

# Enable ChromaDB integration
CHROMA_ENABLED=true

# ── Advanced Options ──────────────────────────────────────────
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Maximum upload size in MB
MAX_UPLOAD_SIZE=100
